{
  "name": "two-rooms-and-a-boom",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.17.0"
  },
  "description": "Two Rooms and a Boom — Vite/React UI + Cloudflare Workers Durable Objects multiplayer",
  "scripts": {
    "dev": "vite",
    "build": "wrangler types && tsc -b && vite build",
    "postinstall": "npm run build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "check": "npm run build && wrangler deploy --dry-run",
    "types": "wrangler types",
    "test:print": "tsx scripts/test-print-deck.ts",
    "test:multiplayer": "tsx scripts/test-multiplayer.ts",
    "test": "npm run test:print && npm run test:multiplayer"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@cloudflare/workers-types": "^5.20260708.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "wrangler": "^4.110.0"
  }
}
